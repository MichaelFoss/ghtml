{
  "manifest_version": 3,
  "name": "GHTML",
  "description": "Insert sanitized HTML into Gmail compose windows while preserving Gmail editing behavior.",
  "version": "0.0.1",
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://mail.google.com/*"],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "src/sanitizer.js",
        "src/dialog-helpers.js",
        "src/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
